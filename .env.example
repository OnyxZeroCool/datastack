# ============================================================================
# datastack — единый .env. Скопируй в .env и при желании поправь.
#   cp .env.example .env
# ============================================================================

COMPOSE_PROJECT_NAME=datastack

# Платформа образов. linux/amd64 = максимальная переносимость:
#  - Linux x86_64 / Intel Mac  → нативно
#  - Apple Silicon / ARM        → через эмуляцию (Rosetta/qemu), медленнее
PLATFORM=linux/amd64

# ---- MinIO (S3) ------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
WAREHOUSE_BUCKET=warehouse
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---- Hive Metastore (CDP-флейвор из Impala quickstart, Derby внутри) -------
HMS_PORT=9083

# ---- Spark + Iceberg + Jupyter --------------------------------------------
SPARK_MASTER_UI_PORT=8080
SPARK_APP_UI_PORT=4040
SPARK_HISTORY_PORT=18080
JUPYTER_PORT=8888

# ---- Greenplum (MPP, замена Teradata) --------------------------------------
GP_PORT=5432
# Образ andruche/greenplum: пользователь gpadmin, БД gpadmin
GP_USER=gpadmin
GP_PASSWORD=gpadmin
GP_DB=gpadmin

# ---- ClickHouse ------------------------------------------------------------
# native-порт сдвинут на 9100: 9000 занят MinIO S3 API
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9100
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse

# ---- Impala ----------------------------------------------------------------
IMPALA_HS2_PORT=21050
IMPALA_WEBUI_PORT=25000

# ---- Kafka -----------------------------------------------------------------
# хост-порт брокера (внутри сети контейнеры ходят на kafka:9092)
KAFKA_HOST_PORT=29092
KAFKA_UI_PORT=8082

# ---- NiFi ------------------------------------------------------------------
# UI: https://localhost:8443/nifi (self-signed сертификат)
NIFI_PORT=8443
NIFI_USER=nifi
# минимум 12 символов — иначе NiFi проигнорирует и сгенерирует случайный
NIFI_PASSWORD=nifinifinifi

# ---- Superset --------------------------------------------------------------
SUPERSET_PORT=8089
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
# для учебного стенда сойдёт; для чего-то публичного — поменяй
SUPERSET_SECRET_KEY=datastack-not-a-secret

# ---- Airflow ---------------------------------------------------------------
# UI сдвинут на 8081: 8080 занят Spark Master UI
AIRFLOW_WEB_PORT=8081
AIRFLOW_PG_DB=airflow
AIRFLOW_PG_USER=airflow
AIRFLOW_PG_PASSWORD=airflow
AIRFLOW_ADMIN_USER=airflow
AIRFLOW_ADMIN_PASSWORD=airflow
# UID процессов airflow внутри контейнера (на Linux ставь свой `id -u`, чтобы dags/ были writable)
AIRFLOW_UID=50000

# ---- Версии образов (пины для воспроизводимости) ---------------------------
MINIO_TAG=RELEASE.2025-04-22T22-12-26Z
SPARK_ICEBERG_TAG=3.5.5_1.8.1
# HMS-образ берётся из IMPALA_TAG (apache/impala:<tag>-impala_quickstart_hms)
POSTGRES_TAG=16
GREENPLUM_TAG=7-4seg
CLICKHOUSE_TAG=25.3
IMPALA_TAG=4.4.1
AIRFLOW_TAG=2.10.5
KAFKA_TAG=4.2.1
KAFKA_UI_TAG=latest
NIFI_TAG=2.9.0
