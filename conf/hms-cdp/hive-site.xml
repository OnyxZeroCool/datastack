<?xml version="1.0"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<!--
  Конфиг для CDP-флейвора HMS (apache/impala:*-impala_quickstart_hms).
  Это Hive 3.1.3000 — та же сборка, с которой Impala тестируется апстримом,
  поэтому data-запросы Impala по Iceberg здесь работают (в отличие от
  vanilla apache/hive, см. IMPALA-10792).

  База — встроенный Derby в volume (как в impala quickstart). Путь обязан
  совпадать с проверкой в hms-entrypoint.sh: /var/lib/hive/metastore/metastore_db.
-->
<configuration>
  <property>
    <name>javax.jdo.option.ConnectionDriverName</name>
    <value>org.apache.derby.jdbc.EmbeddedDriver</value>
  </property>
  <property>
    <name>javax.jdo.option.ConnectionURL</name>
    <value>jdbc:derby:;databaseName=/var/lib/hive/metastore/metastore_db;create=true</value>
  </property>

  <!-- Iceberg-таблицы внешние — их складываем в MinIO; managed остаётся локальным -->
  <property>
    <name>hive.metastore.warehouse.dir</name>
    <value>/user/hive/warehouse/managed</value>
  </property>
  <property>
    <name>hive.metastore.warehouse.external.dir</name>
    <value>s3a://warehouse/</value>
  </property>

  <!-- Нотификации об изменениях: Impala catalogd подхватывает DDL/DML от Spark
       сам, без INVALIDATE METADATA (event polling включается флагом catalogd).
       Listener задан явно: без него HMS не пишет события в NOTIFICATION_LOG
       и polling крутится вхолостую (jar hive-hcatalog-server-extensions в образе есть). -->
  <property>
    <name>metastore.transactional.event.listeners</name>
    <value>org.apache.hive.hcatalog.listener.DbNotificationListener</value>
  </property>
  <property>
    <name>hive.metastore.dml.events</name>
    <value>true</value>
  </property>
  <property>
    <name>hive.metastore.event.db.notification.api.auth</name>
    <value>false</value>
  </property>

  <!-- Как в impala quickstart: транзакции для managed-таблиц, статистику не собирать -->
  <property>
    <name>hive.support.concurrency</name>
    <value>true</value>
  </property>
  <property>
    <name>hive.txn.manager</name>
    <value>org.apache.hadoop.hive.ql.lockmgr.DbTxnManager</value>
  </property>
  <property>
    <name>hive.stats.autogather</name>
    <value>false</value>
  </property>
</configuration>
